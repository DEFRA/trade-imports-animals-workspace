{
  "hash": "55fcf6fd3bf75bb4445ba23ce28ee24b984aecd0",
  "title": "B2C notifier cannot upload an invalid LARGE commercial invoice attachment",
  "spec": "document/document-upload-invalid-commercial-invoice.spec.ts:65 › Invalid commercial invoice attachment upload › CHED-PP › B2C notifier cannot upload an invalid LARGE commercial invoice attachment",
  "relevance": "validation",
  "outcome": "A B2C notifier builds a complete CHED-PP plant-products pre-notification (import type, origin, reference, two commodities added by commodity-code search with bulk package/quantity/weight detail, gross weight, transport to BCP, goods-movement answers, contacts), then on the Accompanying documents page adds a commercial-invoice document (type + reference REF-124 + issue date 04/12/2025), attaches an oversized PDF and clicks Next — the app rejects it, redirecting to attach?fileTooLarge=true with a GOV.UK error summary reading 'Please fix the following errors / The selected file must be smaller than 10MB'.",
  "errorCopy": {
    "alertSummaryHeading": "Please fix the following errors",
    "message": "The selected file must be smaller than 10MB",
    "assertedAtActionId": 67,
    "assertionLocator": "getByRole('alert')",
    "assertionSource": "document-upload-invalid-commercial-invoice.spec.ts:73",
    "uploadedFile": "/app/resources/file-upload/large-file.pdf",
    "fileInput": "<input type=\"file\" id=\"fileUpload\" name=\"fileUpload\" class=\"govuk-file-upload\">",
    "errorMechanism": "POST attach -> 302 -> GET attach?fileTooLarge=true — the error state is carried in the query string, not in session/flash. Server-side rule surfaced via the standard GOV.UK error summary (role=alert).",
    "note": "Trace records 0 errors because the failure is an expected, asserted validation state — not a test failure."
  },
