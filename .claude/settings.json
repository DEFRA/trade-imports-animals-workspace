{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(bash *)",
      "Bash(sh)",
      "Bash(sh *)",
      "Bash(zsh *)",
      "Bash(nohup *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(node *)",
      "Bash(node -e *)",
      "Bash(node)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(perl *)",
      "Bash(ruby *)",
      "Bash(osascript *)",
      "Bash(deno *)",
      "Bash(deno)",
      "Bash(bun *)",
      "Bash(bun)",
      "Bash(bunx *)",
      "Bash(tsx *)",
      "Bash(ts-node *)",
      "Bash(php *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(env *)",
      "Bash(/usr/bin/env *)",
      "Bash(brew install *)",
      "Bash(brew upgrade *)",
      "Bash(brew uninstall *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm --recursive *)",
      "Bash(find * -delete*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)"
    ],
    "allow": [
      "Bash(~/git/defra/trade-imports-animals-workspace/tools/**)",
      "Bash(~/git/defra/trade-imports-animals-workspace/tools/**:*)",
      "Bash(~/git/defra/trade-imports-animals-workspace/scripts/**)",
      "Bash(~/git/defra/trade-imports-animals-workspace/scripts/**:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(file:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(awk * ~/git/defra/trade-imports-animals-workspace/*)",
      "Bash(sed * ~/git/defra/trade-imports-animals-workspace/*)",
      "Bash(find ~/git/defra/trade-imports-animals-workspace/*)",
      "Bash(find ~/git/defra/trade-imports-animals-workspace/*:*)",
      "Bash(git -C ~/git/defra/trade-imports-animals-workspace/*:*)",
      "Bash(git -C ~/git/defra/trade-imports-animals-workspace:*)",
      "Bash(npm --prefix ~/git/defra/trade-imports-animals-workspace/*:*)",
      "Bash(mvn -f ~/git/defra/trade-imports-animals-workspace/*:*)",
      "Bash(~/git/defra/trade-imports-animals-workspace/repos/*/node_modules/.bin/*:*)",
      "Bash(tim:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-edits.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
