{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(bash *)",
      "Bash(sh)",
      "Bash(sh *)",
      "Bash(zsh *)",
      "Bash(nohup *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(node *)",
      "Bash(node -e *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(brew install *)",
      "Bash(brew upgrade *)",
      "Bash(brew uninstall *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)"
