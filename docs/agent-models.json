{
  "version": 2,
  "subscription": "cursor_pro_claude_pro",
  "note": "Defaults for Cursor Pro + Claude Pro. Session models: picker or /model. Workers: Task model param. Lookup: tools/agent/resolve-model.sh",
  "hosts": {
    "cursor": {
      "session": "Agent chat model picker before triggering the skill",
      "task_spawn": "Task tool model parameter"
    },
    "claude_code": {
      "session": "/model in the chat before triggering the skill",
      "task_spawn": "Task tool model parameter when supported; else omit"
    }
  },
  "roles": {
    "plan": {
      "purpose": "Scoping, Testing Strategy, multi-repo analysis, assumptions",
      "hosts": {
        "cursor": {
          "session_hint": "Reasoning — Sonnet thinking; Opus for complex multi-repo tickets",
          "picker_label": "Claude Sonnet 4.6 (thinking)",
          "session_slug": "claude-4.6-sonnet-medium-thinking",
          "session_slug_complex": "claude-opus-4-8-thinking-high",
          "task_slug": null
        },
        "claude_code": {
          "session_hint": "Sonnet default; Opus for complex tickets",
          "model_command": "/model sonnet",
          "model_command_complex": "/model opus",
          "session_slug": "sonnet",
          "task_slug": null
        }
      }
    },
    "implement": {
      "purpose": "Write code and tests, self-review, stage for developer commit",
      "must_differ_session_from": ["review-orchestrator"],
      "hosts": {
        "cursor": {
          "session_hint": "Composer pool — daily coding",
          "picker_label": "Composer 2.5",
          "session_slug": "composer-2.5-fast",
          "task_slug": null
        },
        "claude_code": {
          "session_hint": "Sonnet daily driver; Opus for hard refactors",
          "model_command": "/model sonnet",
          "model_command_complex": "/model opus",
          "session_slug": "sonnet",
          "task_slug": null
        }
      }
    },
    "refactor": {
      "purpose": "Post-green tidy-up — same bar as implement",
      "same_as": "implement"
    },
    "review-orchestrator": {
      "purpose": "Fresh/refresh aggregation, consistency, verdict — fresh eyes vs implement",
      "must_differ_session_from": ["implement"],
      "hosts": {
        "cursor": {
          "session_hint": "Different from implement — Opus or Sonnet, not Composer",
          "picker_label": "Claude Opus 4.8",
          "session_slug": "claude-opus-4-8-thinking-high",
          "task_slug": null
        },
        "claude_code": {
          "session_hint": "New session — not the implement chat",
          "model_command": "/model opus",
          "model_command_fallback": "/model sonnet",
          "session_slug": "opus",
          "task_slug": null
        }
      }
    },
    "review-worker": {
      "purpose": "Per-file FILE_REVIEWER / STYLE_FILE_REVIEWER — scripted JSON output",
      "hosts": {
        "cursor": {
          "session_hint": null,
          "picker_label": null,
          "session_slug": null,
          "task_slug": "gemini-3.5-flash"
        },
        "claude_code": {
          "session_hint": null,
          "model_command": null,
          "session_slug": null,
          "task_slug": "haiku"
        }
      }
    },
    "style-worker": {
      "purpose": "Mechanical style fixes — same tier as review-worker",
      "same_as": "review-worker"
    }
  },
  "bindings": {
    "plan eudpa-": { "session_role": "plan" },
    "implement eudpa-": { "session_role": "implement" },
    "build eudpa-": { "session_role": "implement" },
    "refactor": { "session_role": "refactor" },
    "tidy up": { "session_role": "refactor" },
    "review eudpa-": { "session_role": "review-orchestrator" },
    "re-review": { "session_role": "review-orchestrator" },
    "style review eudpa-": { "session_role": "review-orchestrator" },
    "implement review": { "session_role": "implement" },
    "implement style": { "session_role": "implement" },
    "review.file_reviewer": { "worker_role": "review-worker" },
    "review.consistency_reviewer": { "worker_role": "review-orchestrator" },
    "code-style.fresh_or_refresh_worker": { "worker_role": "review-worker" },
    "code-style.style_implementor": { "worker_role": "style-worker" }
  }
}
