# macOS
.DS_Store

# IDE
.idea/

# Claude Code local settings (contains personal paths) — but track checked-in skills/agents/project-settings
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/settings.json

# Runtime cache for agent skills (review/style/upgrade workspaces, ticket plans, etc.)
# Use `workareas/*` (not `workareas/`) so git descends into the dir and can
# re-include shared/ below — the dir-form `workareas/` would stop descent.
workareas/*
# Exception: shared/ is the handoff namespace — artifacts committed to handoff branches
!workareas/shared/

# Agent AI memory (local only)
agents/memory/

# Local-only scripts (personal, never committed)
tools/review/prepare-ac-check.sh

# Cloned repos — run `make setup` to populate
repos/

# Synced Confluence docs (generated, not committed)
docs/confluence/

# Symlink to local cdp-documentation repo
docs/cdp